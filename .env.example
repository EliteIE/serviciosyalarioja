# =====================================================================
# Frontend env vars (Vite). All vars MUST be prefixed VITE_ to be exposed
# to the client bundle. Copy this file to .env.local and fill in values.
# =====================================================================

# --- Sentry error tracking (optional) ---
# Leave empty to disable Sentry completely (zero bundle cost).
# Get DSN from https://sentry.io -> Project Settings -> Client Keys (DSN).
VITE_SENTRY_DSN=
# Override environment label (default: vite MODE).
VITE_SENTRY_ENV=production
# Set to your git SHA on deploy for source-map / release tracking.
VITE_SENTRY_RELEASE=
